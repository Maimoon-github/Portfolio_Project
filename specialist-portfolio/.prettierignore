# ─────────────────────────────────────────────────────────────
dist/
build/
out/
target/
*.tsbuildinfo
.next/
.nuxt/
.vuepress/dist
.serverless/

# ─────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────
node_modules/
jspm_packages/

