# API Configuration
API_BASE_URL=https://api.example.com/v1    # Base URL for backend API

# Feature Flags
FEATURE_FLAG_NEW_PAYMENT=false              # Enable new payment flow (true/false)
FEATURE_FLAG_DARK_MODE=true                  # Enable dark mode theme

# Analytics
ANALYTICS_ID=UA-XXXXXXXXX-X                  # Google Analytics tracking ID

# Contact Form
CONTACT_FORM_ENDPOINT=https://api.example.com/contact  # Endpoint for contact form submissions

# Application Environment (development, staging, production)
NODE_ENV=development

# Server Port (for local development)
PORT=3000