# .env.example – Template for environment variables
# Copy this file to .env and replace placeholder values with your actual configuration.
# All variables prefixed with VITE_ are exposed to the client-side code.

# Application
VITE_APP_NAME="The Data Specialist"
VITE_APP_URL=http://localhost:5173

# API
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_TIMEOUT=10000

# Features – toggle features on/off (true/false)
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NEW_PAYMENT=false
VITE_FEATURE_ANALYTICS=false

# Analytics (Google Analytics / gtag)
VITE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Contact form submission endpoint
VITE_CONTACT_FORM_ENDPOINT=http://localhost:3000/contact

# Server port (for local development backend)
PORT=3000